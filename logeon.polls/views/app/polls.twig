{% extends 'app/layouts/layout.twig' %}

{% block content %}
<section class="container-fluid py-3" data-module-page="polls">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <header>
            <h4 class="display-6 mb-1">Sondaggi</h4>
            <h6 class="mb-0">Partecipa ai sondaggi anonimi della community in modo rapido e senza pressione sociale.</h6>
        </header>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="polls-game-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-lg-3">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Attivi</div><div class="h4 mb-0" data-role="polls-game-summary-active">0</div></div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Chiusi</div><div class="h4 mb-0" data-role="polls-game-summary-closed">0</div></div></div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header"><strong>Sondaggi attivi</strong></div>
                <div class="card-body" data-role="polls-game-active">
                    <div class="text-muted small">Caricamento...</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header"><strong>Sondaggi chiusi</strong></div>
                <div class="card-body" data-role="polls-game-closed">
                    <div class="text-muted small">Caricamento...</div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

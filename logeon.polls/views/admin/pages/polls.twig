<div class="mt-3" data-admin-page="polls">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <header>
            <h4 class="display-6 mb-1">Sondaggi</h4>
            <h6 class="mb-0">Raccogli feedback anonimo della community con sondaggi semplici e non invasivi.</h6>
        </header>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="polls-admin-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-lg-3">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Totali</div><div class="h4 mb-0" data-role="polls-summary-total">0</div></div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Bozze</div><div class="h4 mb-0" data-role="polls-summary-draft">0</div></div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Attivi</div><div class="h4 mb-0" data-role="polls-summary-active">0</div></div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Chiusi</div><div class="h4 mb-0" data-role="polls-summary-closed">0</div></div></div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-5">
            <div class="card h-100">
                <div class="card-header"><strong>Configura sondaggio</strong></div>
                <div class="card-body">
                    <form data-role="polls-admin-form" class="row g-2">
                        <input type="hidden" name="id" value="0">
                        <div class="col-12">
                            <label class="form-label">Titolo</label>
                            <input type="text" class="form-control form-control-sm" name="title" maxlength="160">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descrizione</label>
                            <textarea class="form-control form-control-sm" name="description" rows="3"></textarea>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Stato</label>
                            <select class="form-select form-select-sm" name="status">
                                <option value="draft">Bozza</option>
                                <option value="active">Attivo</option>
                                <option value="closed">Chiuso</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Visibilità</label>
                            <select class="form-select form-select-sm" name="visibility">
                                <option value="player_only">Solo giocatori</option>
                                <option value="public">Pubblico</option>
                                <option value="staff_only">Solo staff</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Apre il</label>
                            <input type="datetime-local" class="form-control form-control-sm" name="opens_at">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Chiude il</label>
                            <input type="datetime-local" class="form-control form-control-sm" name="closes_at">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Opzioni (2-5)</label>
                            <div data-role="polls-options-container" class="d-grid gap-2"></div>
                            <div class="d-flex gap-2 mt-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="polls-admin-add-option">Aggiungi opzione</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="polls-admin-reset">Reset</button>
                            </div>
                        </div>
                        <div class="col-12 d-flex gap-2 mt-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="polls-admin-save">Salva sondaggio</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card h-100">
                <div class="card-header"><strong>Archivio sondaggi</strong></div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Sondaggio</th>
                                    <th class="text-center">Stato</th>
                                    <th class="text-center">Voti</th>
                                    <th class="text-end">Azioni</th>
                                </tr>
                            </thead>
                            <tbody data-role="polls-admin-table">
                                <tr><td colspan="4" class="text-muted small">Caricamento...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3 d-none" data-role="polls-admin-results-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Risultati</strong>
            <span class="small text-muted" data-role="polls-admin-results-title"></span>
        </div>
        <div class="card-body" data-role="polls-admin-results-body"></div>
    </div>
</div>

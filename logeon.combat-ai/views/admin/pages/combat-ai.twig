<div class="mt-3" data-admin-page="combat-ai">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <header>
            <h4 class="display-6 mb-1">Combattimento AI</h4>
            <h6 class="mb-0">Profili AI per suggerimenti e dichiarazione staff-guidata delle azioni.</h6>
        </header>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="combat-ai-admin-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-xl-5">
            <div class="card h-100">
                <div class="card-header"><strong>Profilo AI</strong></div>
                <div class="card-body">
                    <form class="row g-2" data-role="combat-ai-form">
                        <input type="hidden" name="id" value="0">
                        <div class="col-12">
                            <label class="form-label">Conflitto</label>
                            <select class="form-select form-select-sm" name="conflict_id"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Personaggio</label>
                            <input type="number" class="form-control form-control-sm" name="character_id" min="1">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Comportamento</label>
                            <select class="form-select form-select-sm" name="behavior_key"></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Modalita</label>
                            <select class="form-select form-select-sm" name="automation_mode"></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Focus</label>
                            <select class="form-select form-select-sm" name="priority_focus"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Note</label>
                            <textarea class="form-control form-control-sm" name="notes" rows="2"></textarea>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="combat-ai-profile-save">Salva profilo</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="combat-ai-profile-reset">Reset</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card h-100">
                <div class="card-header"><strong>Stato modulo</strong></div>
                <div class="card-body">
                    <div class="small text-muted mb-2" data-role="combat-ai-tier-state">
                        Verifica dipendenza Narrative Combat...
                    </div>
                    <div class="small text-muted">
                        Il modulo suggerisce una linea d'azione per i partecipanti profilati e consente allo staff di dichiararla con un click.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>Profili registrati</strong></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Personaggio</th>
                            <th class="text-center">Behavior</th>
                            <th class="text-center">Modalita</th>
                            <th class="text-center">Focus</th>
                            <th class="text-end">Azioni</th>
                        </tr>
                    </thead>
                    <tbody data-role="combat-ai-table">
                        <tr><td colspan="5" class="text-muted small">Caricamento...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

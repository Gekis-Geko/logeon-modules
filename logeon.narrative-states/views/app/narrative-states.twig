{% extends theme_shell('game', 'app/layouts/layout.twig') %}

{% block content %}
<main class="container-fluid py-3">
    <header class="mb-3">
        <h4 class="display-6 mb-1">Preset narrativi</h4>
        <p class="text-muted mb-0">
            Questo modulo non sostituisce gli stati narrativi core: ti mostra i preset narrativi
            assegnati al personaggio e ti permette di applicare bundle di stati in modo coerente.
        </p>
    </header>

    <div class="card shadow-sm">
        <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h6 class="mb-0">Preset assegnati</h6>
            <div class="d-flex flex-wrap gap-2">
                <input type="number" class="form-control form-control-sm" id="lfns-scene-id" min="0" placeholder="Scene ID opzionale">
                <button type="button" class="btn btn-sm btn-outline-primary" data-action="lfns-page-reload">Aggiorna</button>
            </div>
        </div>
        <div class="card-body">
            <div class="small text-muted mb-3">
                Per i preset con target <b>scena</b> puoi indicare un `scene/location id` accessibile.
                I preset con target <b>personaggio</b> usano automaticamente il tuo personaggio corrente.
            </div>
            <div id="logeon-narrative-presets-page-list" data-module-key="game.narrative-states"></div>
        </div>
    </div>
</main>
{% endblock %}

<div class="mt-3" data-admin-page="combat-admin-tools">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <header>
            <h4 class="display-6 mb-1">Strumenti di Amministrazione del Combattimento</h4>
            <h6 class="mb-0">Dashboard staff per escalation, rischi di stamina e code di risoluzione.</h6>
        </header>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="combat-admin-tools-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-header"><strong>Stato modulo</strong></div>
                <div class="card-body">
                    <div class="small text-muted" data-role="combat-admin-tools-tier-state">
                        Verifica dipendenza Narrative Combat...
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-8">
            <div class="card h-100">
                <div class="card-header"><strong>Code pending</strong></div>
                <div class="card-body" data-role="combat-admin-tools-pending">
                    <div class="text-muted small">Caricamento...</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>Contesti combattimento</strong></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Conflitto</th>
                            <th class="text-center">Tier</th>
                            <th class="text-center">Escalation</th>
                            <th class="text-center">Attivi</th>
                            <th class="text-center">Rischi</th>
                        </tr>
                    </thead>
                    <tbody data-role="combat-admin-tools-contexts">
                        <tr><td colspan="5" class="text-muted small">Caricamento...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

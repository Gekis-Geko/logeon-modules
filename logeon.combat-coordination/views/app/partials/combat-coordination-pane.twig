<div class="mt-3" data-module-combat-coordination>
    <div class="card border-success-subtle">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h6 class="mb-0">Combat Coordination</h6>
                <div class="small text-muted">Manovre di gruppo e bonus sincronizzati.</div>
            </div>
            <span class="badge text-bg-success" data-role="combat-coordination-badge">Tier 3</span>
        </div>
        <div class="card-body">
            <div class="small text-muted mb-2" data-role="combat-coordination-message">
                Nessun piano coordinato attivo.
            </div>
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="border rounded p-2">
                        <div class="small text-muted mb-2">Piani attivi</div>
                        <div data-role="combat-coordination-plans"></div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="border rounded p-2">
                        <div class="small text-muted mb-2">Nuovo piano</div>
                        <div class="row g-2">
                            <div class="col-12">
                                <select class="form-select form-select-sm" data-role="coord-leader"></select>
                            </div>
                            <div class="col-12">
                                <select class="form-select form-select-sm" data-role="coord-maneuver">
                                    <option value="focus_fire">Focus Fire</option>
                                    <option value="shield_wall">Shield Wall</option>
                                    <option value="extraction">Extraction</option>
                                    <option value="suppressive_push">Suppressive Push</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <select class="form-select form-select-sm" data-role="coord-target"></select>
                            </div>
                            <div class="col-12">
                                <input type="text" class="form-control form-control-sm" data-role="coord-supporters" placeholder="Supporter IDs: 12, 15">
                            </div>
                            <div class="col-12">
                                <button type="button" class="btn btn-sm btn-outline-success" data-action="combat-coordination-save">Salva piano</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

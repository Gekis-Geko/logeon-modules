<div class="mt-3" data-admin-page="combat-coordination">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <header>
            <h4 class="display-6 mb-1">Combat Coordination</h4>
            <h6 class="mb-0">Manovre coordinate, supporto di gruppo e consumazione automatica su risoluzione.</h6>
        </header>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="combat-coordination-admin-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-xl-5">
            <div class="card h-100">
                <div class="card-header"><strong>Piano coordinato</strong></div>
                <div class="card-body">
                    <form class="row g-2" data-role="combat-coordination-form">
                        <input type="hidden" name="id" value="0">
                        <div class="col-12">
                            <label class="form-label">Conflitto</label>
                            <select class="form-select form-select-sm" name="conflict_id"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Leader</label>
                            <input type="number" class="form-control form-control-sm" name="leader_id" min="1">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Target primario</label>
                            <input type="number" class="form-control form-control-sm" name="primary_target_id" min="0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Manovra</label>
                            <select class="form-select form-select-sm" name="maneuver_key"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bonus scale</label>
                            <input type="number" class="form-control form-control-sm" name="bonus_scale" min="1" max="3" value="1">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Supporter IDs</label>
                            <input type="text" class="form-control form-control-sm" name="supporter_ids" placeholder="12, 15, 18">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Note</label>
                            <textarea class="form-control form-control-sm" name="notes" rows="2"></textarea>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="combat-coordination-plan-save">Salva piano</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="combat-coordination-plan-reset">Reset</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card h-100">
                <div class="card-header"><strong>Stato modulo</strong></div>
                <div class="card-body">
                    <div class="small text-muted" data-role="combat-coordination-tier-state">
                        Verifica dipendenza Narrative Combat...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>Piani registrati</strong></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Piano</th>
                            <th class="text-center">Azione</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Azioni</th>
                        </tr>
                    </thead>
                    <tbody data-role="combat-coordination-table">
                        <tr><td colspan="4" class="text-muted small">Caricamento...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

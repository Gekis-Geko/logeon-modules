{% extends theme_shell('game', 'app/layouts/layout.twig') %}

{% block content %}
<main class="container-fluid py-3">
    <header class="mb-3">
        <h4 class="display-6 mb-1">Oggetti avanzati</h4>
        <p class="text-muted mb-0">
            Qui trovi gli oggetti avanzati assegnati dal modulo al tuo personaggio, con stato d'uso
            reale per cariche, durabilita e munizioni.
        </p>
    </header>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0">I tuoi oggetti avanzati</h6>
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="lfai-page-reload">Aggiorna</button>
        </div>
        <div class="card-body">
            <div id="advanced-items-page-list" data-module-key="game.advanced-items"></div>
        </div>
    </div>
</main>
{% endblock %}

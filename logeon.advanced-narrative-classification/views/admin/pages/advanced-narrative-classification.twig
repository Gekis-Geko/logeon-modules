<div class="mt-3" data-admin-page="advanced-narrative-classification">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <header>
            <h4 class="display-6 mb-1">Classificazione narrativa avanzata</h4>
            <h6 class="mb-0">Tassonomie leggere, alias controllati e discovery trasversale sopra i tag narrativi core.</h6>
        </header>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="anc-admin-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>

    <div class="row g-3 mb-3" data-role="anc-admin-summary">
        <div class="col-6 col-lg-2">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Tassonomie</div><div class="h4 mb-0" data-role="anc-summary-taxonomies">0</div></div></div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Nodi</div><div class="h4 mb-0" data-role="anc-summary-nodes">0</div></div></div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Alias</div><div class="h4 mb-0" data-role="anc-summary-aliases">0</div></div></div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Link tag</div><div class="h4 mb-0" data-role="anc-summary-links">0</div></div></div>
        </div>
        <div class="col-6 col-lg-4">
            <div class="card h-100"><div class="card-body py-2"><div class="small text-muted">Tag core non mappati</div><div class="h4 mb-0 text-warning" data-role="anc-summary-orphans">0</div></div></div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-header"><strong>Tassonomia</strong></div>
                <div class="card-body">
                    <form data-role="anc-taxonomy-form" class="row g-2">
                        <input type="hidden" name="id" value="0">
                        <div class="col-12">
                            <label class="form-label">Slug</label>
                            <input type="text" class="form-control form-control-sm" name="slug" maxlength="80">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Nome</label>
                            <input type="text" class="form-control form-control-sm" name="name" maxlength="120">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descrizione</label>
                            <textarea class="form-control form-control-sm" name="description" rows="2" maxlength="255"></textarea>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Ordine</label>
                            <input type="number" class="form-control form-control-sm" name="sort_order" value="0">
                        </div>
                        <div class="col-6">
                            <label class="form-label">Stato</label>
                            <select class="form-select form-select-sm" name="is_active">
                                <option value="1">Attiva</option>
                                <option value="0">Inattiva</option>
                            </select>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="anc-taxonomy-save">Salva</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="anc-taxonomy-reset">Reset</button>
                        </div>
                    </form>
                    <hr>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th class="text-center">Nodi</th>
                                    <th class="text-end">Azioni</th>
                                </tr>
                            </thead>
                            <tbody data-role="anc-taxonomies-table">
                                <tr><td colspan="3" class="text-muted small">Caricamento...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-header"><strong>Nodo tassonomico</strong></div>
                <div class="card-body">
                    <form data-role="anc-node-form" class="row g-2">
                        <input type="hidden" name="id" value="0">
                        <div class="col-12">
                            <label class="form-label">Tassonomia</label>
                            <select class="form-select form-select-sm" name="taxonomy_id"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Parent opzionale</label>
                            <select class="form-select form-select-sm" name="parent_id"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Slug</label>
                            <input type="text" class="form-control form-control-sm" name="slug" maxlength="80">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Label</label>
                            <input type="text" class="form-control form-control-sm" name="label" maxlength="120">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descrizione</label>
                            <textarea class="form-control form-control-sm" name="description" rows="2" maxlength="255"></textarea>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Ordine</label>
                            <input type="number" class="form-control form-control-sm" name="sort_order" value="0">
                        </div>
                        <div class="col-6">
                            <label class="form-label">Stato</label>
                            <select class="form-select form-select-sm" name="is_active">
                                <option value="1">Attivo</option>
                                <option value="0">Inattivo</option>
                            </select>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="anc-node-save">Salva</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="anc-node-reset">Reset</button>
                        </div>
                    </form>
                    <hr>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Nodo</th>
                                    <th class="text-center">Tag</th>
                                    <th class="text-end">Azioni</th>
                                </tr>
                            </thead>
                            <tbody data-role="anc-nodes-table">
                                <tr><td colspan="3" class="text-muted small">Caricamento...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-header"><strong>Alias controllato</strong></div>
                <div class="card-body">
                    <form data-role="anc-alias-form" class="row g-2">
                        <input type="hidden" name="id" value="0">
                        <div class="col-12">
                            <label class="form-label">Tag core</label>
                            <select class="form-select form-select-sm" name="tag_id"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Alias</label>
                            <input type="text" class="form-control form-control-sm" name="alias" maxlength="120">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Note</label>
                            <textarea class="form-control form-control-sm" name="notes" rows="2" maxlength="255"></textarea>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Stato</label>
                            <select class="form-select form-select-sm" name="is_active">
                                <option value="1">Attivo</option>
                                <option value="0">Inattivo</option>
                            </select>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="anc-alias-save">Salva</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="anc-alias-reset">Reset</button>
                        </div>
                    </form>
                    <hr>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Alias</th>
                                    <th>Tag</th>
                                    <th class="text-end">Azioni</th>
                                </tr>
                            </thead>
                            <tbody data-role="anc-aliases-table">
                                <tr><td colspan="3" class="text-muted small">Caricamento...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header"><strong>Mappa tag ↔ nodo</strong></div>
                <div class="card-body">
                    <div class="row g-2 align-items-end">
                        <div class="col-12">
                            <label class="form-label">Nodo selezionato</label>
                            <select class="form-select form-select-sm" data-role="anc-node-tags-node-id"></select>
                        </div>
                        <div class="col-12">
                            <div class="border rounded p-2" data-role="anc-node-tags-container" style="max-height: 320px; overflow:auto;">
                                <div class="text-muted small">Seleziona un nodo per gestire i tag collegati.</div>
                            </div>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-primary" data-action="anc-node-tags-save">Salva collegamenti</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="anc-node-tags-select-none">Deseleziona tutto</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header"><strong>Preview discovery</strong></div>
                <div class="card-body">
                    <form class="row g-2 align-items-end" data-role="anc-discovery-form">
                        <div class="col-12">
                            <label class="form-label">Ricerca libera</label>
                            <input type="search" class="form-control form-control-sm" name="query" placeholder="tema, alias, tag, nodo...">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Entità</label>
                            <select class="form-select form-select-sm" name="entity_type">
                                <option value="all">Tutte</option>
                                <option value="quest_definition">Quest</option>
                                <option value="narrative_event">Eventi narrativi</option>
                                <option value="system_event">Eventi di sistema</option>
                                <option value="scene">Scene</option>
                                <option value="faction">Fazioni</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Match</label>
                            <select class="form-select form-select-sm" name="match_mode">
                                <option value="any">Qualsiasi</option>
                                <option value="all">Tutti</option>
                            </select>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-sm btn-primary">Esegui preview</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="anc-discovery-reset">Reset</button>
                        </div>
                    </form>
                    <hr>
                    <div data-role="anc-discovery-output" class="small text-muted">Nessuna preview eseguita.</div>
                </div>
            </div>
        </div>
    </div>
</div>
